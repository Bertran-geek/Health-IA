# ==========================================================
# Health Campaign AI Microservice - Environment configuration
# Copy this file to `.env` and adjust the values.
# ==========================================================

# --- Application ---
APP_NAME="Health Campaign AI"
APP_ENV=production
LOG_LEVEL=INFO
API_PORT=8001

# --- Database (read-only access strongly recommended) ---
# Inside Docker network use host `health_campaign_db` and port 3306
DB_URL=mysql+pymysql://health_user:health_pass@health_campaign_db:3306/health_campaign_manager
# From host machine (outside Docker) use:
# DB_URL=mysql+pymysql://health_user:health_pass@localhost:3307/health_campaign_manager

# Max rows returned by any query (hard safety cap)
DB_MAX_ROWS=1000
# Statement timeout in seconds
DB_QUERY_TIMEOUT=15

# --- LLM (Groq - free online AI) ---
# Get your free API key at https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here
# Available models: llama-3.3-70b-versatile, llama-3.1-8b-instant, mixtral-8x7b-32768, gemma2-9b-it
GROQ_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.0
LLM_TIMEOUT=60

# --- Security ---
# CHANGE THESE SECRETS IN PRODUCTION
JWT_SECRET=change-me-please-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=120
# Comma separated list of valid API keys (alternative to JWT)
API_KEYS=demo-api-key-change-me
# Default admin login for issuing JWT tokens (demo)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# --- Rate limiting ---
RATE_LIMIT=30/minute

# --- CORS ---
CORS_ORIGINS=*

# --- Redis cache (optional) ---
REDIS_ENABLED=false
REDIS_URL=redis://redis:6379/0
CACHE_TTL=300
